{
  "name": "playwright-qa-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Playwright + TypeScript QA automation framework for UI and API testing.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test:ui": "playwright test --grep \"@ui\" --project=chromium --project=firefox --project=webkit",
    "test:api": "playwright test --grep \"@api\" --project=api",
    "test:smoke": "playwright test --grep \"@smoke\"",
    "test:regression": "playwright test --grep \"@regression\"",
    "lint": "eslint . --ext .ts",
    "format": "prettier . --write",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "dependencies": {
    "@playwright/test": "^1.53.0",
    "allure-playwright": "^3.4.1",
    "dotenv": "^16.6.1",
    "playwright": "^1.53.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "allure-commandline": "^2.34.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
